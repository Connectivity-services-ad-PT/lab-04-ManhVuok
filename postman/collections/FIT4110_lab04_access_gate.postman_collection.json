        {
          "name": "POST event without token returns 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"GATE_SCAN\",\n  \"gateId\": \"GATE-01\",\n  \"cardId\": \"RFID-2026-001\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Missing token returns 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "GET gate with invalid gateId returns client error",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/gates/BADID/status",
              "host": ["{{baseUrl}}"],
              "path": ["gates", "BADID", "status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid gateId returns 4xx', function () { pm.expect(pm.response.code).to.be.within(400, 499); });",
                  "pm.test('Error response has title and status', function () { const j = pm.response.json(); pm.expect(j).to.have.property('title'); pm.expect(j).to.have.property('status'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET unknown card returns 404",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/cards/RFID-9999-999",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "RFID-9999-999"]
            }
          },
          "event": [
