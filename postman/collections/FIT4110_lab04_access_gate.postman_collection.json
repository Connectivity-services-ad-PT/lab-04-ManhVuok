      ]
    },
    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "GET recent logs with limit=100 (max) returns 200",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent?limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["access", "logs", "recent"],
              "query": [{ "key": "limit", "value": "100" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Boundary limit=100 returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is still a valid page', function () { const j = pm.response.json(); pm.expect(j.items).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET recent logs with limit=101 (above max) returns 4xx",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent?limit=101",
              "host": ["{{baseUrl}}"],
              "path": ["access", "logs", "recent"],
              "query": [{ "key": "limit", "value": "101" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('limit above max returns 4xx', function () { pm.expect(pm.response.code).to.be.within(400, 499); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET recent logs - access status enum reliability",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent",
              "host": ["{{baseUrl}}"],
              "path": ["access", "logs", "recent"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Every log status is ALLOWED or DENIED', function () { const j = pm.response.json(); j.items.forEach(function (it) { pm.expect(it.status).to.be.oneOf(['ALLOWED','DENIED']); }); });",
                  "pm.test('Response time is acceptable (< 1500ms)', function () { pm.expect(pm.response.responseTime).to.be.below(1500); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
