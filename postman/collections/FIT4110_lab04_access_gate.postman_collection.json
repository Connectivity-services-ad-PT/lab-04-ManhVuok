                  "pm.test('Unknown card returns 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('404 body follows Problem shape', function () { const j = pm.response.json(); pm.expect(j.status).to.eql(404); pm.expect(j).to.have.property('title'); });"
                ]
              }
            }
          ]
        },
        {
