{
  "info": {
    "name": "FIT4110 Lab04 Access Gate Docker Verification",
    "description": "Postman collection (team-gate) verifying the Dockerized Access Gate service against the Lab 03 OpenAPI contract. Uses {{baseUrl}} and {{authToken}} from the environment - no hardcoded values.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET health returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Health reports status ok with service and time', function () { const j = pm.response.json(); pm.expect(j.status).to.eql('ok'); pm.expect(j).to.have.property('service'); pm.expect(j).to.have.property('time'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET recent access logs returns a page",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["access", "logs", "recent"],
              "query": [{ "key": "limit", "value": "5" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is a paginated access-log page', function () { const j = pm.response.json(); pm.expect(j).to.have.property('items'); pm.expect(j.items).to.be.an('array'); pm.expect(j).to.have.property('hasMore'); pm.expect(j).to.have.property('nextCursor'); });",
                  "pm.test('Each access log has the contract fields', function () { const j = pm.response.json(); j.items.forEach(function (it) { pm.expect(it).to.have.property('logId'); pm.expect(it).to.have.property('cardId'); pm.expect(it).to.have.property('gateId'); pm.expect(it.direction).to.be.oneOf(['IN','OUT']); pm.expect(it.status).to.be.oneOf(['ALLOWED','DENIED']); }); });",
                  "const first = pm.response.json().items[0];",
                  "if (first && first.logId) { pm.environment.set('savedLogId', first.logId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET access log by saved logId returns 200",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/access/logs/{{savedLogId}}",
              "host": ["{{baseUrl}}"],
              "path": ["access", "logs", "{{savedLogId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Returned log matches saved logId', function () { const j = pm.response.json(); pm.expect(j.logId).to.eql(pm.environment.get('savedLogId')); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET card info returns 200 with enums",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/cards/RFID-2026-001",
              "host": ["{{baseUrl}}"],
              "path": ["cards", "RFID-2026-001"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Card info matches contract enums', function () { const j = pm.response.json(); pm.expect(j.cardId).to.eql('RFID-2026-001'); pm.expect(j.holderType).to.be.oneOf(['STUDENT','LECTURER','STAFF','VISITOR']); pm.expect(j.status).to.be.oneOf(['ACTIVE','SUSPENDED','EXPIRED','REVOKED']); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET gate status returns 200",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/gates/GATE-01/status",
              "host": ["{{baseUrl}}"],
              "path": ["gates", "GATE-01", "status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Gate status has valid mode and online flag', function () { const j = pm.response.json(); pm.expect(j.gateId).to.eql('GATE-01'); pm.expect(j.mode).to.be.oneOf(['NORMAL','LOCKDOWN','MAINTENANCE','EMERGENCY_OPEN']); pm.expect(j.isOnline).to.be.a('boolean'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST event GATE_SCAN returns 201",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"GATE_SCAN\",\n  \"gateId\": \"GATE-01\",\n  \"cardId\": \"RFID-2026-001\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response returns an eventId', function () { const j = pm.response.json(); pm.expect(j).to.have.property('eventId'); pm.expect(j.eventId).to.be.a('string'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
